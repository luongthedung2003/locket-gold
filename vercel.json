{
    "version": 2,
    "functions": {
        "api/index.php": { "runtime": "vercel-php@0.7.5" }
    },
    "routes": [
        {
            "src": "/(css|js|images|assets)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "https://your-project-name.vercel.app",
        "APP_KEY": "base64:YOUR_GENERATED_KEY_HERE"
    }
}
